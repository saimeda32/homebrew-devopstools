#!/usr/bin/env bash

# Wrapper that runs `scripts/apply_profiles.sh`.
# Works both in the source tree and when installed by Homebrew.
set -euo pipefail

HERE="$(cd "$(dirname "$0")/.." && pwd)"
REPO_SCRIPTS="$HERE/scripts"
BREW_OPT_ROOT="$(brew --prefix 2>/dev/null || echo /opt/homebrew)/opt/devopstools"

# prefer repo-local scripts; otherwise prefer libexec under Homebrew opt, then bin
if [ -x "$REPO_SCRIPTS/apply_profiles.sh" ]; then
  exec "$REPO_SCRIPTS/apply_profiles.sh" "$@"
elif [ -x "$BREW_OPT_ROOT/libexec/apply_profiles.sh" ]; then
  exec "$BREW_OPT_ROOT/libexec/apply_profiles.sh" "$@"
elif [ -x "$BREW_OPT_ROOT/bin/apply_profiles.sh" ]; then
  exec "$BREW_OPT_ROOT/bin/apply_profiles.sh" "$@"
else
  echo "devopstools helper missing: $REPO_SCRIPTS/apply_profiles.sh or $BREW_OPT_ROOT/libexec/apply_profiles.sh" >&2
  exit 2
fi

#!/usr/bin/env bash

# Wrapper that runs `scripts/apply_profiles.sh`.
# Works both in the source tree and when installed by Homebrew.
set -euo pipefail

HERE="$(cd "$(dirname "$0")/.." && pwd)"
REPO_SCRIPTS="$HERE/scripts"

# If installed via Homebrew the libexec path is a reliable fallback
HOMEBREW_LIBEXEC="$(brew --prefix 2>/dev/null || echo /opt/homebrew)/opt/devopstools/libexec"

if [ -x "$REPO_SCRIPTS/apply_profiles.sh" ]; then
  exec "$REPO_SCRIPTS/apply_profiles.sh" "$@"
elif [ -x "$HOMEBREW_LIBEXEC/apply_profiles.sh" ]; then
  exec "$HOMEBREW_LIBEXEC/apply_profiles.sh" "$@"
else
  echo "devopstools helper missing: $REPO_SCRIPTS/apply_profiles.sh or $HOMEBREW_LIBEXEC/apply_profiles.sh" >&2
  exit 2
fi
